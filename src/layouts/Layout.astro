---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  active?: string;         // which nav item to highlight
  noindex?: boolean;
}
const {
  title,
  description = 'Live global coffee prices and a coffee knowledge encyclopedia for farmers, café owners, exporters and enthusiasts.',
  active = '',
  noindex = false,
} = Astro.props;

// On desktop all tabs show inline; on mobile the secondary ones collapse into "More".
// Dashboard + Origins always stay visible; Dashboard is the way back to the home screen.
const navMain = [
  { href: '/',              label: 'Dashboard', key: 'dashboard' },
  { href: '/single-origin', label: 'Origins',   key: 'origins'   },
];
const navSecondary = [
  { href: '/grades',    label: 'Grades',    key: 'grades'    },
  { href: '/brewing',   label: 'Brewing',   key: 'brewing'   },
  { href: '/knowledge', label: 'Knowledge', key: 'knowledge' },
  { href: '/admin',     label: 'Admin',     key: 'admin'     },
];
const moreActive = navSecondary.some((n) => n.key === active);
const year = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☕</text></svg>"
    />
  </head>
  <body class="antialiased">
    <div class="bg-photos" aria-hidden="true">
      <div class="bg-slide s1"></div>
      <div class="bg-slide s2"></div>
      <div class="bg-slide s3"></div>
    </div>
    <div class="bg-scrim" aria-hidden="true"></div>

    <nav class="nav">
      <div class="nav-inner">
        <a class="brand" href="/"><span class="bean-mark"></span><span class="brand-text">Global <b>Coffee</b> Board</span></a>
        <button class="nav-toggle" aria-label="Menu">☰</button>
        <div class="nav-links">
          {navMain.map((n) => (
            <a href={n.href} class={active === n.key ? 'active' : ''}>{n.label}</a>
          ))}
          {navSecondary.map((n) => (
            <a href={n.href} class={`nav-secondary${active === n.key ? ' active' : ''}`}>{n.label}</a>
          ))}
          <div class={moreActive ? 'nav-more has-active' : 'nav-more'}>
            <button class="nav-more-btn" aria-haspopup="true" aria-expanded="false">More <span class="caret" aria-hidden="true">▾</span></button>
            <div class="nav-more-menu">
              {navSecondary.map((n) => (
                <a href={n.href} class={active === n.key ? 'active' : ''}>{n.label}</a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="wrap">
        <div class="footer-grid">
          <div>
            <div class="brand" style="margin-bottom:10px"><span class="bean-mark"></span><span class="brand-text">Global <b>Coffee</b> Board</span></div>
            <p style="color:var(--text-muted);font-size:.92rem;max-width:340px">Global coffee knowledge and a daily price dashboard for the whole coffee community — with a special focus on Indian growers.</p>
          </div>
          <div>
            <h5>Explore</h5>
            <a href="/#dashboard">Live Dashboard</a>
            <a href="/single-origin">Single-Origin Explorer</a>
            <a href="/brewing">Calculators &amp; Brewing</a>
            <a href="/grades">Grades &amp; Differentials</a>
            <a href="/knowledge">Knowledge Base</a>
          </div>
          <div>
            <h5>Data sources</h5>
            <a href="https://coffeeboard.gov.in/Market_Info.aspx" target="_blank" rel="noopener">Coffee Board of India — daily report</a>
            <a href="https://www.tradingview.com/symbols/ICEUS-KC1!/" target="_blank" rel="noopener">TradingView — live charts</a>
            <a href="https://www.exchangerate-api.com" target="_blank" rel="noopener">ExchangeRate-API — USD/INR</a>
          </div>
        </div>
        <div class="fine">© {year} GlobalCoffeeBoard.com · Prices are indicative and for information only — not financial advice.</div>
      </div>
    </footer>

    <!-- shared client behaviour -->
    <script is:inline src="/assets/js/config.js"></script>
    <script is:inline src="/assets/js/main.js"></script>
    <slot name="scripts" />
  </body>
</html>
