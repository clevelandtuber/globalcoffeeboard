---
import Layout from '../layouts/Layout.astro';
import LiveMarket from '../components/LiveMarket.astro';
---
<Layout
  title="Global Coffee Board — Live Coffee Prices & Knowledge"
  description="Live global coffee prices (London Robusta, NY Arabica), USD/INR, and the Coffee Board of India daily market report — plus an earnings calculator and a coffee knowledge encyclopedia."
  active="dashboard"
>
  <header class="hero">
    <div class="wrap">
      <div class="eyebrow">Global coffee intelligence · from bean to benchmark</div>
      <h1>The world's coffee prices,<br /><span class="grad">clear enough for a farmer.</span></h1>
      <p class="lead">Live London Robusta &amp; New York Arabica benchmarks, USD/INR, and the Coffee Board of India daily report — converted to ₹/kg with a plain-language "sell or hold" verdict.</p>
      <div class="hero-cta">
        <a href="#dashboard" class="btn btn-primary">View live prices</a>
        <a href="/knowledge" class="btn btn-ghost">Explore knowledge →</a>
      </div>
      <div class="scroll-hint">scroll to the dashboard ↓</div>
    </div>
  </header>

  <main>
    <LiveMarket />

    <section class="section" id="dashboard">
      <div class="wrap">
        <div class="section-head reveal">
          <div class="eyebrow">Live Price Dashboard</div>
          <h2>Today's coffee market</h2>
          <p>Benchmarks refresh automatically. When the live feed is unavailable, the latest admin-entered figures are shown.</p>
          <div style="display:flex;gap:14px;justify-content:center;align-items:center;margin-top:14px;flex-wrap:wrap">
            <span class="live-dot"><i></i> Updated <b id="updated-at" style="color:var(--text)">—</b></span>
            <button class="btn" id="refresh-btn" style="padding:8px 16px">↻ Refresh</button>
          </div>
        </div>

        <div class="price-grid reveal">
          <div class="glass price-card" id="card-robusta"></div>
          <div class="glass price-card" id="card-arabica"></div>
          <div class="glass price-card" id="card-fx"></div>
          <div class="glass price-card" id="card-local"></div>
        </div>

        <div class="verdict hold reveal" id="verdict"></div>
        <div style="margin-top:22px" class="reveal" id="differential"></div>
      </div>
    </section>

    <section class="section" id="cbi">
      <div class="wrap">
        <div class="section-head reveal">
          <div class="eyebrow">Coffee Board of India</div>
          <h2>Daily Coffee Market Report</h2>
          <p>Official Indian farm-gate grade prices (₹), auto-updated from the <a style="color:var(--gold-2)" href="https://coffeeboard.gov.in/Market_Info.aspx" target="_blank" rel="noopener">Coffee Board of India daily report ↗</a>. <span id="cbi-date" style="color:var(--text-dim)"></span></p>
        </div>
        <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:24px;align-items:start" class="cbi-layout">
          <div class="glass reveal" style="padding:14px 14px 6px">
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0 4px 10px">
              <span class="eyebrow">Farm-gate grades (Karnataka)</span>
              <span id="cbi-badge" class="src-badge"></span>
            </div>
            <div class="table-wrap">
              <table class="data">
                <thead><tr><th>Grade</th><th style="text-align:right">₹ / 50 kg</th><th style="text-align:right">₹ / kg</th></tr></thead>
                <tbody id="cbi-body"></tbody>
              </table>
            </div>
          </div>
          <div class="glass reveal" style="padding:24px 24px 40px">
            <div class="eyebrow">Price by grade (₹/50kg)</div>
            <div class="bars" id="cbi-chart" style="margin-top:26px"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="calculator">
      <div class="wrap">
        <div class="section-head reveal">
          <div class="eyebrow">Earnings Calculator</div>
          <h2>What is your harvest worth today?</h2>
          <p>Pick a bean, choose a quantity, and see the value at today's prices.</p>
        </div>
        <div class="glass reveal" style="padding:30px">
          <div class="calc">
            <div>
              <div class="field">
                <label>Bean type</label>
                <div class="chip-row">
                  <div class="chip active" data-bean="robusta">Robusta</div>
                  <div class="chip" data-bean="arabica">Arabica</div>
                </div>
              </div>
              <div class="field">
                <label>Quantity</label>
                <div class="chip-row">
                  <div class="chip" data-qty="1">1 kg</div>
                  <div class="chip" data-qty="50">50 kg (bag)</div>
                  <div class="chip active" data-qty="60">60 kg (bag)</div>
                  <div class="chip" data-qty="100">100 kg</div>
                  <div class="chip" data-qty="1000">1 tonne</div>
                  <div class="chip" data-qty="custom">Custom</div>
                </div>
                <input id="qty-custom" type="number" inputmode="numeric" placeholder="Enter kg" style="display:none;margin-top:10px" />
              </div>
              <p style="color:var(--text-dim);font-size:.85rem">Based on today's <b>futures</b> prices (Robusta US$/tonne, Arabica US¢/lb) from the Admin panel, converted to ₹/kg at the live USD/INR rate.</p>
            </div>
            <div class="glass calc-result" id="calc-out">
              <div class="eyebrow">Estimated value</div>
              <div class="earn" data-earn>—</div>
              <div class="earn-sub" data-earn-sub>—</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="audience">
      <div class="wrap">
        <div class="section-head reveal">
          <div class="eyebrow">Built for everyone in coffee</div>
          <h2>Whoever you are, start here</h2>
        </div>
        <div class="aud-grid reveal">
          <a class="glass aud" href="/knowledge#farmers"><div class="a-ico">🌾</div><h4>Farmers</h4><p>Daily prices in ₹/kg, sell-or-hold guidance and an earnings calculator.</p></a>
          <a class="glass aud" href="/knowledge#enthusiasts"><div class="a-ico">☕</div><h4>Enthusiasts</h4><p>Origins, varieties, processing and brewing — the whole bean story.</p></a>
          <a class="glass aud" href="/knowledge#entrepreneurs"><div class="a-ico">💼</div><h4>Café owners</h4><p>Costing, sourcing and market trends to price your menu with confidence.</p></a>
          <a class="glass aud" href="/knowledge#exporters"><div class="a-ico">🚢</div><h4>Exporters</h4><p>Benchmarks, differentials and FX to time shipments and contracts.</p></a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="wrap">
        <div class="section-head reveal">
          <div class="eyebrow">Coffee Encyclopedia</div>
          <h2>Learn the craft, from cherry to cup</h2>
          <p>A growing knowledge base for the global coffee community.</p>
        </div>
        <div class="k-grid reveal">
          <a href="/knowledge#varieties" class="glass k-card tilt"><div class="k-ico">🫘</div><h3>Arabica vs Robusta</h3><p>Flavour, caffeine, altitude and why the price gap exists.</p><span class="k-tag">Read →</span></a>
          <a href="/knowledge#processing" class="glass k-card tilt"><div class="k-ico">💧</div><h3>Processing methods</h3><p>Washed, natural and honey — and how each shapes the cup.</p><span class="k-tag">Read →</span></a>
          <a href="/knowledge#india" class="glass k-card tilt"><div class="k-ico">🇮🇳</div><h3>Indian coffee regions</h3><p>Karnataka, Kerala, Tamil Nadu and the monsooned Malabar story.</p><span class="k-tag">Read →</span></a>
        </div>
        <div style="text-align:center;margin-top:30px" class="reveal">
          <a href="/knowledge" class="btn btn-primary">Open the encyclopedia</a>
        </div>
      </div>
    </section>
  </main>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/dashboard.js"></script>
    <script is:inline src="https://unpkg.com/three@0.160.0/build/three.min.js"></script>
    <script is:inline src="/assets/js/scene.js"></script>
  </Fragment>
</Layout>
