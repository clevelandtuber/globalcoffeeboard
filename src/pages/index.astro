---
import Layout from '../layouts/Layout.astro';
import LiveMarket from '../components/LiveMarket.astro';
---
<Layout
  title="Global Coffee Board — Live Coffee Prices & Knowledge"
  description="Live global coffee prices (London Robusta, NY Arabica), USD/INR, and the Coffee Board of India daily market report — plus an earnings calculator and a coffee knowledge encyclopedia."
  active="dashboard"
>
  <header class="hero">
    <div class="wrap">
      <div class="eyebrow">Global coffee intelligence · from bean to benchmark</div>
      <h1>The world's coffee prices,<br /><span class="grad">clear enough for a farmer.</span></h1>
      <p class="lead">Live London Robusta &amp; New York Arabica benchmarks, USD/INR, and the Coffee Board of India daily report — converted to ₹/kg with a plain-language "sell or hold" verdict.</p>
      <div class="hero-cta">
        <a href="#dashboard" class="btn btn-primary">View live prices</a>
        <a href="#calculator" class="btn btn-ghost">Farmer Harvest Price →</a>
      </div>
      <div class="scroll-hint">scroll to the dashboard ↓</div>
    </div>
  </header>

  <main>
    <LiveMarket />

    <section class="section" id="dashboard">
      <div class="wrap">
        <div class="section-head reveal">
          <div class="eyebrow">Live Price Dashboard</div>
          <h2>Today's coffee market</h2>
          <div style="display:flex;gap:14px;justify-content:center;align-items:center;margin-top:8px;flex-wrap:wrap">
            <span class="live-dot"><i></i> USD/INR updated <b id="updated-at" style="color:var(--text)">—</b></span>
            <button class="btn" id="refresh-btn" style="padding:8px 16px">↻ Refresh USD/INR</button>
          </div>
        </div>

        <div class="price-grid reveal">
          <div class="glass price-card" id="card-robusta"></div>
          <div class="glass price-card" id="card-arabica"></div>
          <div class="glass price-card" id="card-fx"></div>
          <div class="glass price-card" id="card-local-robusta"></div>
          <div class="glass price-card" id="card-local-arabica"></div>
        </div>

        <div class="raw-head reveal">
          <div>
            <span class="eyebrow">Coffee Board of India</span>
            <h3 class="raw-title">Indian Raw Coffee Price</h3>
          </div>
          <div class="raw-meta">
            <span id="cbi-badge" class="src-badge"></span>
            <span style="color:var(--text-dim);font-size:.85rem">As on <b id="raw-date" style="color:var(--text-muted)">—</b> · ₹ / kg</span>
          </div>
        </div>
        <div class="raw-grid" id="raw-grid"></div>
      </div>
    </section>

    <section class="section" style="padding-top:0">
      <div class="wrap">
        <div class="verdict hold reveal" id="verdict"></div>
      </div>
    </section>

    <section class="section" id="calculator">
      <div class="wrap">
        <div class="section-head reveal">
          <div class="eyebrow">Earnings Calculator</div>
          <h2>What is your harvest worth today?</h2>
          <p>Pick a bean, enter your outturn, and see the value at today's prices.</p>
        </div>
        <div class="glass reveal" style="padding:30px">
          <div class="calc">
            <div>
              <div class="field">
                <label>Bean type</label>
                <div class="chip-row">
                  <div class="chip active" data-bean="robusta">Robusta</div>
                  <div class="chip" data-bean="arabica">Arabica</div>
                </div>
              </div>
              <div class="field">
                <label>Quantity (Outturn)</label>
                <input id="outturn" type="number" step="1" min="0" value="0" placeholder="Outturn — yield in kg (e.g. 26)" style="font-size:1.6rem;padding:16px 18px;font-weight:700" />
                <div style="font-size:.95rem;color:var(--text-dim);margin:9px 2px 4px">Outturn = clean-coffee yield in kg</div>
              </div>
              <div class="field">
                <label>Differential (US$/tonne) <span style="color:var(--text-dim);font-weight:400;text-transform:none;letter-spacing:0">— default 250, editable</span></label>
                <input id="calc-diff" type="number" step="1" value="250" />
              </div>
              <p style="color:var(--text-dim);font-size:.85rem">Value = ((<b>futures</b> price + differential) ÷ 1000) × USD/INR × kg — where <b>kg = your outturn</b> (yield) unless you pick a fixed quantity. Futures price &amp; USD/INR come from the cards; the differential (US$/tonne) defaults to 250 and is editable.</p>
            </div>
            <div class="glass calc-result" id="calc-out">
              <div class="eyebrow">Estimated value</div>
              <div class="earn" data-earn>—</div>
              <div class="earn-sub" data-earn-sub>—</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top:0">
      <div class="wrap" style="text-align:center">
        <a href="/knowledge" class="btn btn-primary">Open the coffee encyclopedia</a>
      </div>
    </section>
  </main>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/dashboard.js"></script>
  </Fragment>
</Layout>
