---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Admin — Daily Futures Entry · Global Coffee Board"
  active="admin"
  noindex={true}
>
  <header class="hero" style="padding:60px 0 20px">
    <div class="wrap">
      <div class="eyebrow">Admin panel</div>
      <h1 style="font-size:clamp(2rem,4.5vw,3rem)">Daily futures entry</h1>
      <p class="lead">Enter today's <b>coffee futures</b> prices for Robusta and Arabica. These feed the price cards and the earnings calculator on the dashboard. USD/INR updates automatically and doesn't need entry. Data is stored in your browser (localStorage).</p>
    </div>
  </header>

  <main>
    <section class="section" style="padding-top:10px">
      <div class="wrap" style="max-width:760px">

        <div id="admin-notice" class="notice info" style="display:none"></div>

        <div class="notice info">
          <b>Where to read today's numbers:</b> use the live charts on the
          <a style="color:var(--gold-2)" href="/#dashboard">dashboard</a> (or
          <a style="color:var(--gold-2)" href="https://www.tradingview.com/symbols/ICEUS-KC1!/" target="_blank" rel="noopener">TradingView</a>).
          Robusta is quoted in <b>US$ per tonne</b>; Arabica in <b>US cents per pound</b> (¢/lb).
        </div>

        <div class="glass" style="padding:26px;margin-bottom:22px">
          <h3 style="font-family:var(--font-head);margin-bottom:4px">Coffee futures prices</h3>
          <p style="color:var(--text-dim);font-size:.85rem;margin-bottom:16px">"Prev. close" is optional — it's only used to show the ▲/▼ change on the cards.</p>
          <div class="admin-grid">
            <div class="field"><label>London Robusta — futures (US$ / tonne)</label><input id="robusta" type="number" inputmode="decimal" placeholder="e.g. 3960" /></div>
            <div class="field"><label>Robusta prev. close (US$ / tonne)</label><input id="robustaPrev" type="number" inputmode="decimal" placeholder="e.g. 3900" /></div>
            <div class="field"><label>NY Arabica — futures (US ¢ / lb)</label><input id="arabica" type="number" inputmode="decimal" placeholder="e.g. 320" /></div>
            <div class="field"><label>Arabica prev. close (¢ / lb)</label><input id="arabicaPrev" type="number" inputmode="decimal" placeholder="e.g. 312" /></div>
          </div>
        </div>

        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
          <button class="btn btn-primary" id="save-btn">💾 Save &amp; publish</button>
          <button class="btn" id="export-btn">⬇ Export JSON</button>
          <label class="btn" style="cursor:pointer">⬆ Import JSON<input id="import-file" type="file" accept="application/json" style="display:none" /></label>
          <button class="btn btn-ghost" id="clear-btn" style="margin-left:auto;border-color:rgba(229,106,95,.4);color:var(--bad)">Clear manual data</button>
        </div>

        <p style="color:var(--text-dim);font-size:.85rem;margin-top:18px">
          Note: this is a client-side panel for a static site. Data lives in this browser only. Use <b>Export JSON</b> to back up or move entries to another device, and <b>Import JSON</b> to restore them.
        </p>
      </div>
    </section>
  </main>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/admin.js"></script>
  </Fragment>
</Layout>
